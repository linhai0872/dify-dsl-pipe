# =====================================
# Dify DSL 导出工具配置文件示例
# =====================================

# ===== Dify 配置 =====
# Dify Console API 相关配置
dify:
  # Dify Console API 基础地址（请根据实际部署地址修改）
  # 示例：http://localhost/console/api 或 https://cloud.dify.ai/console/api
  base_url: "http://localhost/console/api"
  
  # ===== 认证方式 1: 使用邮箱和密码登录（推荐）=====
  # Dify 控制台登录邮箱
  email: "your-email@example.com"
  
  # Dify 控制台登录密码
  password: "your-password"
  
  # ===== 认证方式 2: 使用 access_token（高级选项）=====
  # 如果提供了 access_token，将忽略 email 和 password
  # 可以通过浏览器登录后从开发者工具中获取
  # access_token: ""
  
  # 是否导出敏感信息（如环境变量中的 secret 值）
  # true: 导出包含所有敏感信息  false: 不导出敏感信息（推荐）
  include_secret: false
  
  # API 请求超时时间（秒）
  timeout: 30
  
  # API 请求重试次数
  max_retries: 3

# ===== 导出配置 =====
# DSL 导出相关配置
export:
  # 临时文件存储目录
  temp_dir: "/tmp/dify-export"
  
  # 压缩格式（目前仅支持 zip）
  archive_format: "zip"
  
  # 是否在上传后删除本地临时文件
  cleanup_after_upload: true
  
  # 导出的应用类型过滤（留空表示导出所有类型）
  # 可选值：chat, agent-chat, completion, workflow, advanced-chat
  app_types: []
  
  # 是否导出历史版本（仅对 workflow 和 advanced-chat 类型应用有效）
  # true: 导出所有已发布的历史版本到 versions/ 子目录，并生成版本信息文件
  # false: 只导出当前版本（默认）
  export_version_history: true
  
  # 是否将应用标签添加到文件名中
  # true: 文件名格式为 AppName-Tag1-Tag2.yml
  # false: 文件名格式为 AppName.yml（默认）
  include_tags_in_filename: false

# ===== 存储后端配置 =====
# 选择存储后端并配置相应参数
storage:
  # 存储后端类型
  # 可选值: local, aliyun_oss, aws_s3, minio, volcengine, tencent_cos
  backend: "local"
  
  # ===== 本地存储配置 =====
  local:
    # 本地存储路径
    # 注意：Python 和 Docker 运行都会读取此配置
    # - Python 运行：直接使用此路径
    # - Docker 运行：需要在 docker-compose.yml 中配置相应的 volumes 映射
    #   示例：如果此处配置 "/opt/dify-backups"，则 docker-compose.yml 应配置
    #   volumes: - /opt/dify-backups:/opt/dify-backups
    path: "/opt/dify-backups"
  
  # ===== 阿里云 OSS 配置 =====
  aliyun_oss:
    # OSS Endpoint（区域节点）
    # 示例：oss-cn-hangzhou.aliyuncs.com, oss-cn-beijing.aliyuncs.com
    endpoint: "oss-cn-hangzhou.aliyuncs.com"
    
    # AccessKey ID
    access_key_id: ""
    
    # AccessKey Secret
    access_key_secret: ""
    
    # Bucket 名称
    bucket_name: ""
    
    # 文件前缀路径（可选）
    prefix: "dify-backups/"
    
    # 是否使用内网 Endpoint（在阿里云 ECS 上可启用以节省流量费用）
    use_internal_endpoint: false
  
  # ===== AWS S3 配置 =====
  aws_s3:
    # AWS 区域
    # 示例：us-east-1, us-west-2, ap-northeast-1
    region: "us-east-1"
    
    # AWS Access Key ID
    access_key_id: ""
    
    # AWS Secret Access Key
    secret_access_key: ""
    
    # S3 Bucket 名称
    bucket_name: ""
    
    # 文件前缀路径（可选）
    prefix: "dify-backups/"
    
    # 自定义 Endpoint（可选，用于兼容 S3 协议的对象存储）
    endpoint_url: ""
  
  # ===== MinIO 配置 =====
  minio:
    # MinIO 服务地址
    # 示例：localhost:9000, minio.example.com:9000
    endpoint: "localhost:9000"
    
    # Access Key
    access_key: ""
    
    # Secret Key
    secret_key: ""
    
    # Bucket 名称
    bucket_name: ""
    
    # 文件前缀路径（可选）
    prefix: "dify-backups/"
    
    # 是否使用 HTTPS
    secure: true
  
  # ===== 火山云 TOS 配置 =====
  volcengine:
    # TOS Endpoint（区域节点）
    # 示例：tos-cn-beijing.volces.com, tos-cn-guangzhou.volces.com
    endpoint: "tos-cn-beijing.volces.com"
    
    # Access Key ID
    access_key_id: ""
    
    # Secret Access Key
    secret_access_key: ""
    
    # Bucket 名称
    bucket_name: ""
    
    # 文件前缀路径（可选）
    prefix: "dify-backups/"
    
    # 区域代码
    region: "cn-beijing"
  
  # ===== 腾讯云 COS 配置 =====
  tencent_cos:
    # COS 区域
    # 示例：ap-guangzhou, ap-shanghai, ap-beijing
    region: "ap-guangzhou"
    
    # SecretId
    secret_id: ""
    
    # SecretKey
    secret_key: ""
    
    # Bucket 名称（格式：BucketName-APPID）
    bucket_name: ""
    
    # 文件前缀路径（可选）
    prefix: "dify-backups/"

# ===== 日志配置 =====
# 日志输出相关配置
logging:
  # 日志级别
  # 可选值: DEBUG, INFO, WARNING, ERROR, CRITICAL
  level: "INFO"
  
  # 日志文件路径（留空表示只输出到控制台）
  file: ""
  
  # 日志格式
  # 可选值: simple, detailed
  format: "detailed"

