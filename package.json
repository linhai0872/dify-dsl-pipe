{
  "name": "dify-dsl-pipe",
  "version": "0.2.1",
  "description": "Dify DSL 一站式管道工具 — 导出、导入、跨实例迁移",
  "type": "module",
  "bin": {
    "dify-dsl-pipe": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dify",
    "dsl",
    "backup",
    "export",
    "import",
    "migration",
    "cli"
  ],
  "author": "linhai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/linhai0872/dify-dsl-pipe.git"
  },
  "homepage": "https://github.com/linhai0872/dify-dsl-pipe#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@clack/prompts": "^0.9.0",
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.0.0",
    "croner": "^10.0.1",
    "hono": "^4.12.18",
    "picocolors": "^1.1.0",
    "semver": "^7.6.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.5.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
